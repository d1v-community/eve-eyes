{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "next start",
    "test": "node --test ./tests/**/*.test.mjs",
    "db:create-migration": "node ./scripts/create-migration.mjs",
    "db:migrate": "node ./scripts/run-migrations.mjs",
    "api-key:test:local": "bash ./scripts/test-api-key-local.sh",
    "api-key:test:remote": "bash ./scripts/test-api-key-remote.sh",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write './src/**/*.{js,jsx,ts,tsx}'",
    "deploy:firebase:init": "firebase login && firebase use --add",
    "deploy:firebase": "firebase deploy --only hosting",
    "deploy:walrus:testnet": "pnpm build && pnpx walrus-sites-deploy -n testnet",
    "deploy:walrus:mainnet": "pnpm build && pnpx walrus-sites-deploy -n mainnet",
    "deploy:arweave": "ARWEAVE_DEPLOYMENT=true pnpm run build && pnpx arkb deploy ./dist -w ./arweave-keyfile.json --auto-confirm"
  },
  "dependencies": {
    "@mysten/dapp-kit": "^1.0.4",
    "@mysten/sui": "^1.45.2",
    "@mysten/wallet-standard": "^0.19.9",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/themes": "^3.2.1",
    "@deck.gl/core": "^9.2.2",
    "@deck.gl/layers": "^9.2.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.0",
    "@suiware/kit": "^0.11.1",
    "@tanstack/react-query": "^5.90.12",
    "clsx": "^2.1.1",
    "graphology": "^0.26.0",
    "lucide-react": "^0.561.0",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-use": "^17.6.0",
    "sigma": "^3.0.2",
    "three": "^0.181.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.181.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}
