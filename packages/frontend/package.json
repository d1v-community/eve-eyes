{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "next start",
    "test": "node --test ./tests/**/*.test.mjs",
    "db:create-migration": "node ./scripts/create-migration.mjs",
    "db:migrate": "node ./scripts/run-migrations.mjs",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write './src/**/*.{js,jsx,ts,tsx}'",
    "deploy:firebase:init": "firebase login && firebase use --add",
    "deploy:firebase": "firebase deploy --only hosting",
    "deploy:walrus:testnet": "pnpm build && pnpx walrus-sites-deploy -n testnet",
    "deploy:walrus:mainnet": "pnpm build && pnpx walrus-sites-deploy -n mainnet",
    "deploy:arweave": "ARWEAVE_DEPLOYMENT=true pnpm run build && pnpx arkb deploy ./dist -w ./arweave-keyfile.json --auto-confirm"
  },
  "dependencies": {
    "@mysten/dapp-kit": "^1.0.4",
    "@mysten/sui": "^2.9.1",
    "@mysten/wallet-standard": "^0.20.1",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/themes": "^3.3.0",
    "@suiware/kit": "^0.11.1",
    "@tanstack/react-query": "^5.91.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-use": "^17.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.3",
    "eslint-config-next": "16.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  }
}
