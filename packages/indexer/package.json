{
  "name": "indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node ./src/main.mjs",
    "subscribe:package": "node ./scripts/subscribe-package-transactions.mjs",
    "backfill:package": "node ./scripts/backfill-package-transaction-blocks.mjs",
    "backfill:package:smoke": "node ./scripts/backfill-package-transaction-blocks.mjs --smoke",
    "db:find:failed-move-calls": "node ./scripts/find-failed-transactions-with-move-calls.mjs",
    "once": "INDEXER_RUN_ONCE=true node ./src/main.mjs",
    "pipeline": "node ./scripts/pipeline.mjs",
    "db:import:suiscan": "node ./scripts/import-suiscan-csv.mjs",
    "db:sync:suiscan-rpc": "node ./scripts/sync-suiscan-rpc.mjs",
    "db:watch:suiscan-rpc": "node ./scripts/watch-sync-suiscan-rpc.mjs",
    "db:sync:transaction-block-move-calls": "node ./scripts/sync-transaction-block-move-calls.mjs",
    "db:watch:transaction-block-move-calls": "node ./scripts/watch-transaction-block-move-calls.mjs",
    "db:sync:derived-records": "node ./scripts/sync-transaction-block-derived-records.mjs",
    "db:watch:derived-records": "node ./scripts/watch-transaction-block-derived-records.mjs",
    "db:sync:user-activities": "node ./scripts/sync-transaction-block-user-activities.mjs",
    "db:watch:user-activities": "node ./scripts/watch-transaction-block-user-activities.mjs",
    "db:backfill:user-activities": "node ./scripts/backfill-user-activities-until-empty.mjs"
  },
  "dependencies": {
    "@mysten/sui": "^2.12.0",
    "postgres": "^3.4.8"
  }
}
